{
  "builds": [
    {
      "src": "src/app.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "runtime": "python3.11"
      }
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "src/static/$1"
    },
    {
      "src": "/(.*)",
      "dest": "src/app.py"
    }
  ],
  "env": {
    "PYTHONPATH": "/var/task/src",
    "VERCEL": "1"
  }
}
